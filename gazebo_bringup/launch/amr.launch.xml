<launch>
    <arg name="world" default="empty_sensors"
         description="World file to load (empty_sensors | warehouse | office)" />
    <let name="gazebo_config_path" value="$(find-pkg-share gazebo_bringup)/config/gazebo_bridge.yaml" />
    <let name="urdf_path" value="$(find-pkg-share amr_description)/urdf/robot.urdf.xacro" />
  
    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file"
        value="$(var gazebo_config_path)" />
    </node>

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
        value="$(command 'xacro $(var urdf_path)')" />
        <param name="use_sim_time" value="true" />
    </node>

    <include
        file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="-r $(find-pkg-share gazebo_bringup)/worlds/$(var world).sdf" />
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description -z 0.1" />
    
    <!-- <node pkg="slam_toolbox" exec="async_slam_toolbox_node"
          name="slam_toolbox" output="screen">
        <param name="use_sim_time" value="true"/>
        <param from="$(find-pkg-share gazebo_bringup)/config/slam_toolbox_params.yaml"/>
    </node> -->

    <!-- <include file="$(find-pkg-share nav2_bringup)/launch/nav2.launch.xml"/> --> -->

    <node pkg="rviz2" exec="rviz2"
          args="-d $(find-pkg-share amr_description)/rviz/amr.rviz">
        <param name="use_sim_time" value="true"/>
        <env name="MESA_GL_VERSION_OVERRIDE" value="3.3"/>
        <env name="MESA_GLSL_VERSION_OVERRIDE" value="330"/>
    </node>

</launch>
